# ── Rust ────────────────────────────────────────────────────────────────
target/
**/*.rs.bk

# ── Node.js ─────────────────────────────────────────────────────────────
node_modules/

# ── Foundry ─────────────────────────────────────────────────────────────
contracts/cache/
contracts/broadcast/
contracts/out/
contracts/foundry.lock

# ── IDE ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Build artifacts ─────────────────────────────────────────────────────
*.elf
*.bin

# ── Environment / secrets ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ── ZKMist CLI cache ────────────────────────────────────────────────────
# Large files downloaded by `zkmist fetch` (~2.8 GB eligibility list,
# proof cache, guest ELF binary). Lives in the user's home directory.
.zkmist/

# ── KZG SRS / Powers-of-Tau ceremony transcripts ───────────────────────
# Multi-GB binary trust-root artifacts that must NEVER be committed. The
# deployer obtains & verifies them locally (docs/kzg-srs.md); the pinned
# SHA-256 in cli/src/constants.rs is the only thing stored in-repo.
# `ppot_*.ptau` = raw MPC transcript; `.srs-work/` = scratch dir for the
# PSE halo2-kzg-srs converter + downloaded transcript.
*.ptau
.srs-work/

# ── Proof files ─────────────────────────────────────────────────────────
# Contain user-specific nullifiers and serialized receipts.
zkmist_proof_*.json

# ── Real-KZG round-trip fixture (generated, may be a forgeable dev-SRS proof) ─
# Produced by `zkmist gen-roundtrip-fixture`, consumed by the Forge test
# contracts/test/ZKM.realroundtrip.t.sol. Never commit: it is a build artifact
# and, under ZKMIST_DEV_SRS, a forgeable proof that must not masquerade as a
# trusted fixture.
contracts/fixtures/

# ── Logs ────────────────────────────────────────────────────────────────
*.log
.logs/

# ── Coverage / test artifacts ───────────────────────────────────────────
*.profraw
lcov.info
coverage/

# ── Temporary / scratch files ───────────────────────────────────────────
*.tmp
*.bak
*.orig

# Third-party tool artifacts
.antigravitycli/
contracts/Halo2Verifier.axiom.sol
